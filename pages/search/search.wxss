/* pages/search/search.wxss */
.search-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 搜索头部 */
.search-header {
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

/* 搜索建议 */
.suggestions {
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  max-height: 400rpx;
  overflow-y: auto;
}

.suggestion-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.suggestion-item:active {
  background: #f5f5f5;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #666;
}

/* 预搜索状态 */
.pre-search {
  padding: 20rpx;
}

/* AI状态 */
.ai-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
}

.ai-status.disconnected {
  background: #fff5f5;
  color: #d54941;
}

.ai-status.connected {
  background: #f0fff4;
  color: #07a35a;
}

/* 分区 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.tag-item.hot {
  background: #fff5f0;
  color: #e37318;
}

.tag-item:active {
  background: #e8e8e8;
}

/* 示例问题 */
.example-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #f8f5ff;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
}

.example-item:active {
  background: #f0ebff;
}

/* 搜索结果 */
.search-results {
  padding: 20rpx;
}

.result-section {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 30rpx;
  background: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.copy-btn {
  padding: 8rpx;
  margin-left: auto;
}

.result-list {
  padding: 10rpx;
}

.result-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.result-item:last-child {
  border-bottom: none;
}

.result-type {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.result-formula {
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #0052d9;
  background: #f0f7ff;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  word-break: break-all;
  line-height: 1.5;
}

.result-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.result-category {
  font-size: 22rpx;
  color: #999;
}

/* AI搜索中 */
.ai-searching {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.ai-hint {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.ai-hint text {
  font-size: 26rpx;
  color: #8b5cf6;
}

/* AI响应结果 */
.ai-section {
  border: 2rpx solid #e9d5ff;
}

.ai-response-content {
  padding: 30rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

/* AI错误 */
.ai-error {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.error-content {
  padding: 24rpx 30rpx;
  font-size: 26rpx;
  color: #d54941;
}

.error-hint {
  padding: 16rpx 30rpx 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* 无结果 */
.no-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.no-result-text {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #666;
}

.no-result-hint {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #999;
}

/* 重新搜索 */
.retry-section {
  padding: 40rpx;
  text-align: center;
}

.retry-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #0052d9;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.retry-btn:active {
  opacity: 0.8;
}
