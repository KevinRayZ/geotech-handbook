/* pages/test/test.wxss */
.test-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.page-header {
  background: linear-gradient(135deg, #0052d9, #0084ff);
  padding: 40rpx;
  color: #fff;
}

.page-header .title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.page-header .subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

/* 统计卡片 */
.stats-card {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #0052d9;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 测试列表 */
.test-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.test-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.retest-btn {
  font-size: 26rpx;
  color: #0052d9;
  font-weight: 400;
}

.test-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.test-item:last-child {
  border-bottom: none;
}

.test-icon {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.test-content {
  flex: 1;
}

.test-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.test-message {
  font-size: 24rpx;
  color: #666;
}

.test-error {
  font-size: 24rpx;
  color: #d54941;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}
