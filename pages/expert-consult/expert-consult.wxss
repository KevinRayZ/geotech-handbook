/* pages/expert-consult/expert-consult.wxss */
.consult-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部说明 */
.header-section {
  background: linear-gradient(135deg, #1a73e8, #0d47a1);
  padding: 40rpx 30rpx;
  text-align: center;
  color: #fff;
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.disclaimer-box {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: rgba(255,255,255,0.15);
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  text-align: left;
  line-height: 1.6;
}

/* 专家区域 */
.expert-section {
  margin: 24rpx 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #64748b;
}

/* 专家卡片 */
.expert-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.expert-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  transition: all 0.3s ease;
}

.expert-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.12);
}

.expert-card.international {
  border-left: 6rpx solid #3b82f6;
}

.expert-card.domestic {
  border-left: 6rpx solid #f59e0b;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-avatar {
  font-size: 56rpx;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: #f0f7ff;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.international .card-avatar {
  background: #eff6ff;
}

.domestic .card-avatar {
  background: #fef3c7;
}

.card-info {
  flex: 1;
}

.card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 4rpx;
}

.card-title {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 4rpx;
}

.card-era {
  font-size: 22rpx;
  color: #94a3b8;
}

.card-bio {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.card-models {
  margin-bottom: 20rpx;
}

.models-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 12rpx;
}

.model-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.model-tag {
  font-size: 22rpx;
  color: #1a73e8;
  background: #e3f2fd;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #90caf9;
}

.international .model-tag {
  color: #1e40af;
  background: #dbeafe;
  border-color: #93c5fd;
}

.domestic .model-tag {
  color: #92400e;
  background: #fef3c7;
  border-color: #fbbf24;
}

.card-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  font-size: 26rpx;
  color: #1a73e8;
  font-weight: 600;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}

/* 接口预留说明 */
.api-notice {
  margin: 24rpx 20rpx;
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
  border: 2rpx solid #86efac;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #166534;
  margin-bottom: 12rpx;
}

.notice-desc {
  font-size: 24rpx;
  color: #4ade80;
  line-height: 1.6;
}
