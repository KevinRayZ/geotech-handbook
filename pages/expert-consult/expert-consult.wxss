/* pages/expert-consult/expert-consult.wxss */
.expert-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 免责声明 */
.disclaimer-banner {
  margin: 20rpx;
  background: #fff7ed;
  border: 2rpx solid #e37318;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.disclaimer-content {
  flex: 1;
}

.disclaimer-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.disclaimer-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 分区 */
.section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 专家列表 */
.expert-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.expert-card {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e8f0fe;
}

.expert-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.expert-avatar {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f0fe;
  border-radius: 50%;
  flex-shrink: 0;
}

.expert-basic {
  flex: 1;
}

.expert-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.expert-title {
  font-size: 24rpx;
  color: #666;
}

.expert-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.expert-specialties {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.expert-models {
  background: #fff;
  padding: 16rpx;
  border-radius: 12rpx;
}

.model-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.model-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.model-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 使用方式 */
.usage-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.usage-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.usage-step {
  width: 48rpx;
  height: 48rpx;
  background: #0052d9;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.usage-content {
  flex: 1;
}

.usage-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.usage-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 服务特点 */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
