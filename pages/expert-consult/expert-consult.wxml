<!--pages/expert-consult/expert-consult.wxml-->
<view class="consult-page">
  <!-- 顶部说明 -->
  <view class="header-section">
    <view class="header-icon">🤖</view>
    <view class="header-title">AI专家对话</view>
    <view class="header-desc">
      基于AI蒸馏技术，还原专家思维框架，为您提供专业的岩土工程咨询服务
    </view>
    <view class="disclaimer-box">
      <t-icon name="info-circle" size="16px" color="#e37318"/>
      <text>本服务基于AI蒸馏专家思维框架，非专家本人服务。回复仅供参考学习，不构成专业建议。</text>
    </view>
  </view>

  <!-- 国际专家 -->
  <view class="expert-section">
    <view class="section-header">
      <view class="section-title">🌍 国际专家</view>
      <view class="section-desc">世界级岩土工程大师</view>
    </view>
    
    <view class="expert-list">
      <view 
        class="expert-card international"
        wx:for="{{internationalExperts}}" 
        wx:key="id"
        data-expert="{{item}}"
        bind:tap="onExpertTap"
      >
        <view class="card-header">
          <view class="card-avatar">{{item.avatar}}</view>
          <view class="card-info">
            <view class="card-name">{{item.name}}</view>
            <view class="card-title">{{item.title}}</view>
            <view class="card-era">{{item.era}} · {{item.country}}</view>
          </view>
        </view>
        
        <view class="card-bio">{{item.bio}}</view>
        
        <view class="card-models">
          <view class="models-title">核心贡献：</view>
          <view class="model-tags">
            <view class="model-tag" wx:for="{{item.mentalModels}}" wx:for-item="model" wx:key="name">
              {{model.name}}
            </view>
          </view>
        </view>
        
        <view class="card-action">
          <text>开始对话</text>
          <t-icon name="chevron-right" size="16px"/>
        </view>
      </view>
    </view>
  </view>

  <!-- 国内专家 -->
  <view class="expert-section">
    <view class="section-header">
      <view class="section-title">🇨🇳 国内专家</view>
      <view class="section-desc">中国岩土工程领军人物</view>
    </view>
    
    <view class="expert-list">
      <view 
        class="expert-card domestic"
        wx:for="{{domesticExperts}}" 
        wx:key="id"
        data-expert="{{item}}"
        bind:tap="onExpertTap"
      >
        <view class="card-header">
          <view class="card-avatar">{{item.avatar}}</view>
          <view class="card-info">
            <view class="card-name">{{item.name}}</view>
            <view class="card-title">{{item.title}}</view>
            <view class="card-era">{{item.era}} · {{item.country}}</view>
          </view>
        </view>
        
        <view class="card-bio">{{item.bio}}</view>
        
        <view class="card-models">
          <view class="models-title">核心贡献：</view>
          <view class="model-tags">
            <view class="model-tag" wx:for="{{item.mentalModels}}" wx:for-item="model" wx:key="name">
              {{model.name}}
            </view>
          </view>
        </view>
        
        <view class="card-action">
          <text>开始对话</text>
          <t-icon name="chevron-right" size="16px"/>
        </view>
      </view>
    </view>
  </view>

  <!-- 接口预留说明 -->
  <view class="api-notice">
    <view class="notice-title">📡 持续更新</view>
    <view class="notice-desc">
      我们正在接入更多国内外岩土工程专家的思维框架，敬请期待！
    </view>
  </view>
</view>
