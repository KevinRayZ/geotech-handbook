/* pages/profile/profile.wxss */

.container {
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  position: relative;
  overflow: hidden;
}

.user-bg {
  height: 200rpx;
  background: linear-gradient(135deg, #1976d2, #1565c0);
}

.user-content {
  position: relative;
  padding: 0 32rpx;
}

/* 登录区域 */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  margin-top: -60rpx;
}

.login-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.login-text {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.login-btn {
  width: 300rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #fff;
  color: #1976d2;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx;
  border: none;
}

.login-btn:active {
  opacity: 0.9;
}

/* 已登录区域 */
.logged-section {
  display: flex;
  align-items: center;
  padding: 40rpx 0;
  margin-top: -60rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-right: 24rpx;
  background: #e0e0e0;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-company {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 4rpx;
}

.user-position {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

/* 统计数据 */
.stats-card {
  display: flex;
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1976d2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
}

.stat-divider {
  width: 1rpx;
  background: #e0e0e0;
  margin: 0 16rpx;
}

/* 区域卡片 */
.section-card {
  background: #fff;
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.section-action {
  font-size: 26rpx;
  color: #1976d2;
  margin-left: 20rpx;
}

.section-action.cancel {
  color: #999;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.info-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 8rpx 12rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.info-input.picker {
  display: flex;
  align-items: center;
  min-height: 60rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 8rpx 12rpx;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f9fa;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-content {
  flex: 1;
}

.menu-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.menu-note {
  font-size: 22rpx;
  color: #999;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #d32f2f;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: 1rpx solid #d32f2f;
}

.logout-btn:active {
  background: #ffebee;
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.footer-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 8rpx;
}

.footer-version {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.footer-copyright {
  font-size: 22rpx;
  color: #bbb;
}
