/* pages/index/index.wxss */
.index-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 欢迎区域 */
.welcome-section {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

.welcome-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #0052d9, #0084ff);
}

.welcome-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 40rpx;
  color: #fff;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 28rpx;
  opacity: 0.8;
}

/* 状态卡片 */
.status-card {
  margin: -40rpx 20rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 2;
}

.status-icon {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.status-content {
  flex: 1;
}

.status-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: #666;
}

/* 功能入口 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.feature-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: all 0.3s ease;
}

.feature-item.primary {
  background: linear-gradient(135deg, #f5f3ff, #ede9fe);
  border: 2rpx solid #8b5cf6;
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.2);
}

.feature-item.primary .feature-name {
  color: #6d28d9;
}

.feature-item.primary .feature-desc {
  color: #7c3aed;
}

.feature-item:active {
  transform: scale(0.98);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
}

/* AI专家咨询入口 - 双入口样式 */
.expert-section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.expert-section .section-title {
  margin-bottom: 12rpx;
}

.expert-disclaimer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #e37318;
  background: #fff7ed;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.expert-dual-entry {
  display: flex;
  gap: 20rpx;
}

.expert-entry {
  flex: 1;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e2e8f0;
  transition: all 0.3s ease;
}

.expert-entry:active {
  transform: scale(0.98);
  border-color: #1a73e8;
}

.expert-entry.international {
  background: linear-gradient(135deg, #eff6ff, #dbeafe);
  border-color: #93c5fd;
}

.expert-entry.domestic {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-color: #fbbf24;
}

.entry-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.entry-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(0,0,0,0.1);
}

.international .entry-badge {
  color: #1e40af;
  background: rgba(30, 64, 175, 0.1);
}

.domestic .entry-badge {
  color: #92400e;
  background: rgba(146, 64, 14, 0.1);
}

.entry-avatar {
  font-size: 48rpx;
  text-align: center;
  margin: 12rpx 0;
}

.entry-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 4rpx;
}

.entry-title {
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 16rpx;
}

.entry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: center;
  margin-bottom: 16rpx;
}

.entry-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #1a73e8;
  font-weight: 600;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.more-experts {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #1a73e8;
  background: #f0f7ff;
  border-radius: 12rpx;
}

.more-experts:active {
  background: #e0efff;
}

/* 专项方案咨询入口 */
.consultation-banner {
  margin: 20rpx;
  background: linear-gradient(135deg, #fff7ed, #ffedd5);
  border: 2rpx solid #e37318;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(227, 115, 24, 0.15);
}

.banner-left {
  flex-shrink: 0;
}

.banner-center {
  flex: 1;
}

.banner-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: #666;
}

/* 快速搜索 */
.quick-search {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.search-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.search-tag:active {
  background: #e8e8e8;
}

/* 知识分类 */
.category-section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.category-list {
  margin-top: 20rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-item:last-child {
  border-bottom: none;
}

.category-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}
