/* pages/index/index.wxss */
.index-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 欢迎区域 */
.welcome-section {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

.welcome-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #0052d9, #0084ff);
}

.welcome-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 40rpx;
  color: #fff;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 28rpx;
  opacity: 0.8;
}

/* 状态卡片 */
.status-card {
  margin: -40rpx 20rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 2;
}

.status-icon {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.status-content {
  flex: 1;
}

.status-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: #666;
}

/* 功能入口 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.feature-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: all 0.3s ease;
}

.feature-item.primary {
  background: linear-gradient(135deg, #f5f3ff, #ede9fe);
  border: 2rpx solid #8b5cf6;
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.2);
}

.feature-item.primary .feature-name {
  color: #6d28d9;
}

.feature-item.primary .feature-desc {
  color: #7c3aed;
}

.feature-item:active {
  transform: scale(0.98);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
}

/* 快速搜索 */
.quick-search {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.search-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.search-tag:active {
  background: #e8e8e8;
}

/* 知识分类 */
.category-section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.category-list {
  margin-top: 20rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-item:last-child {
  border-bottom: none;
}

.category-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}
