/* pages/advisor/advisor.wxss */

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 工程类型选择 */
.type-section {
  margin-bottom: 24rpx;
}

.selected-type {
  background-color: #E8F0FE !important;
  border-radius: 12rpx;
}

/* 参数输入 */
.params-section {
  margin-bottom: 24rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  min-width: 200rpx;
}

/* 即将推出 */
.coming-soon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.coming-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-top: 24rpx;
}

.coming-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 推荐按钮 */
.action-section {
  margin-bottom: 32rpx;
}

/* 推荐结果 */
.result-section {
  margin-top: 32rpx;
}

.scheme-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.primary-card {
  border: 2rpx solid #0052D9;
}

.scheme-badge {
  margin-bottom: 16rpx;
}

.scheme-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.scheme-notes {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.scheme-params {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.params-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.param-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.param-item:last-child {
  border-bottom: none;
}

.param-name {
  font-size: 26rpx;
  color: #666;
}

.param-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

/* 备选方案 */
.alternatives-section {
  margin-bottom: 24rpx;
}

.section-subtitle {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.alternative-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.alternative-card .scheme-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 0;
}

/* 警告信息 */
.warnings-section {
  margin-bottom: 24rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background-color: #FFF8E1;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.warning-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
}
