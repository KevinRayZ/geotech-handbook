/* pages/advisor/advisor.wxss */

.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 顶部说明 */
.notice-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff7ed;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #fed7aa;
}

.notice-text {
  font-size: 24rpx;
  color: #c2410c;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

/* 工程类型选择 */
.type-grid {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-item.selected {
  background: #e3f2fd;
  border-color: #1976d2;
}

.type-item:active {
  transform: scale(0.98);
}

.type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

/* 参数输入 */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.form-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  border: 1rpx solid #e5e5e5;
  font-size: 28rpx;
}

.form-input:focus {
  border-color: #1976d2;
  background: #fff;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  padding: 16rpx 28rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e5e5e5;
  transition: all 0.2s;
}

.radio-item.selected {
  background: #e3f2fd;
  color: #1976d2;
  border-color: #1976d2;
}

.radio-item:active {
  transform: scale(0.98);
}

/* 推荐按钮 */
.action-section {
  margin-bottom: 32rpx;
}

.recommend-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1976d2, #1565c0);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.recommend-btn.disabled {
  background: #ccc;
  color: #999;
}

.recommend-btn:active {
  opacity: 0.9;
}

/* 推荐结果 */
.result-section {
  margin-top: 32rpx;
}

.scheme-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.primary-card {
  border: 2rpx solid #1976d2;
}

.scheme-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.scheme-badge {
  padding: 8rpx 16rpx;
  background: #1976d2;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 6rpx;
}

.scheme-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.scheme-type {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.scheme-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 信息块 */
.info-block {
  margin-bottom: 24rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.info-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
}

/* 优缺点 */
.pros-cons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.pros, .cons {
  flex: 1;
  padding: 16rpx;
  border-radius: 8rpx;
}

.pros {
  background: #f0fdf4;
  border: 1rpx solid #86efac;
}

.cons {
  background: #fef2f2;
  border: 1rpx solid #fca5a5;
}

.pros-title, .cons-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.pros-title {
  color: #166534;
}

.cons-title {
  color: #991b1b;
}

.pros-item, .cons-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.pros-icon {
  color: #22c55e;
  font-weight: bold;
}

.cons-icon {
  color: #ef4444;
  font-weight: bold;
}

/* 设计参数 */
.design-params {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.params-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.param-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.param-item:last-child {
  border-bottom: none;
}

.param-name {
  font-size: 26rpx;
  color: #666;
}

.param-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

/* 安全系数 */
.safety-factor {
  background: #eff6ff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #93c5fd;
}

.factor-title {
  font-size: 26rpx;
  color: #1e40af;
  margin-bottom: 8rpx;
}

.factor-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e40af;
}

/* 建议 */
.recommendations {
  margin-bottom: 24rpx;
}

.rec-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.rec-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.rec-icon {
  color: #1976d2;
  font-weight: bold;
}

/* 联系设计院提示 */
.consultation-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #fff7ed;
  border-radius: 8rpx;
  border: 1rpx solid #fed7aa;
}

.consultation-tip text {
  font-size: 26rpx;
  color: #c2410c;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn.outline {
  background: #fff;
  color: #1976d2;
  border: 2rpx solid #1976d2;
}

.action-btn.primary {
  background: linear-gradient(135deg, #e37318, #c2410c);
  color: #fff;
}

.action-btn:active {
  opacity: 0.9;
}
