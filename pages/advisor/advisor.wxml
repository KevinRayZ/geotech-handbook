<!-- pages/advisor/advisor.wxml -->
<view class="container">
  <!-- 工程类型选择 -->
  <view class="type-section card">
    <view class="section-title">选择工程类型</view>
    <t-grid column="{{3}}" border="{{false}}">
      <t-grid-item 
        text="基坑支护" 
        image="/assets/icons/pit.png" 
        bind:tap="selectType" 
        data-type="pit"
        t-class="{{selectedType === 'pit' ? 'selected-type' : ''}}"
      />
      <t-grid-item 
        text="边坡治理" 
        image="/assets/icons/slope.png" 
        bind:tap="selectType" 
        data-type="slope"
        t-class="{{selectedType === 'slope' ? 'selected-type' : ''}}"
      />
      <t-grid-item 
        text="地基处理" 
        image="/assets/icons/foundation.png" 
        bind:tap="selectType" 
        data-type="foundation"
        t-class="{{selectedType === 'foundation' ? 'selected-type' : ''}}"
      />
    </t-grid>
  </view>

  <!-- 基坑方案参数输入 -->
  <view class="params-section card" wx:if="{{selectedType === 'pit'}}">
    <view class="section-title">工程参数</view>
    
    <view class="form-group">
      <view class="form-item">
        <view class="form-label">开挖深度 (m) *</view>
        <t-input 
          type="digit" 
          value="{{params.depth}}" 
          placeholder="请输入开挖深度"
          bind:change="onInputChange"
          data-key="depth"
        />
      </view>

      <view class="form-item">
        <view class="form-label">土质条件 *</view>
        <t-radio-group value="{{params.soilType}}" bind:change="onSoilTypeChange" t-class="radio-group">
          <t-radio value="clay" label="黏性土" t-class="radio-item" />
          <t-radio value="sand" label="砂土" t-class="radio-item" />
          <t-radio value="softSoil" label="软土/淤泥" t-class="radio-item" />
        </t-radio-group>
      </view>

      <view class="form-item">
        <view class="form-label">地下水位深度 (m)</view>
        <t-input 
          type="digit" 
          value="{{params.waterLevel}}" 
          placeholder="距地表深度，无水可不填"
          bind:change="onInputChange"
          data-key="waterLevel"
        />
      </view>

      <view class="form-item">
        <view class="form-label">周边环境 *</view>
        <t-radio-group value="{{params.environment}}" bind:change="onEnvChange" t-class="radio-group">
          <t-radio value="relaxed" label="宽松（无建筑物）" t-class="radio-item" />
          <t-radio value="normal" label="一般（有建筑物）" t-class="radio-item" />
          <t-radio value="strict" label="严格（重要建筑物）" t-class="radio-item" />
        </t-radio-group>
      </view>

      <view class="form-item">
        <view class="form-label">地面超载 (kPa)</view>
        <t-input 
          type="digit" 
          value="{{params.surcharge}}" 
          placeholder="默认10kPa"
          bind:change="onInputChange"
          data-key="surcharge"
        />
      </view>

      <view class="form-item">
        <view class="form-label">基坑安全等级</view>
        <t-radio-group value="{{params.pitLevel}}" bind:change="onPitLevelChange" t-class="radio-group">
          <t-radio value="一级" label="一级" t-class="radio-item" />
          <t-radio value="二级" label="二级" t-class="radio-item" />
          <t-radio value="三级" label="三级" t-class="radio-item" />
        </t-radio-group>
      </view>
    </view>
  </view>

  <!-- 边坡方案参数输入 -->
  <view class="params-section card" wx:if="{{selectedType === 'slope'}}">
    <view class="section-title">工程参数</view>
    <view class="coming-soon">
      <t-icon name="time" size="80rpx" color="#999" />
      <view class="coming-text">边坡方案推荐功能即将上线</view>
      <view class="coming-desc">v1.1版本将支持边坡治理方案推荐</view>
    </view>
  </view>

  <!-- 地基处理方案参数输入 -->
  <view class="params-section card" wx:if="{{selectedType === 'foundation'}}">
    <view class="section-title">工程参数</view>
    <view class="coming-soon">
      <t-icon name="time" size="80rpx" color="#999" />
      <view class="coming-text">地基处理方案推荐功能即将上线</view>
      <view class="coming-desc">v1.2版本将支持地基处理方案推荐</view>
    </view>
  </view>

  <!-- 推荐按钮 -->
  <view class="action-section" wx:if="{{selectedType === 'pit'}}">
    <t-button 
      theme="primary" 
      size="large" 
      block 
      bind:tap="onRecommend"
      loading="{{loading}}"
      disabled="{{!canRecommend}}"
    >
      智能推荐方案
    </t-button>
  </view>

  <!-- 推荐结果 -->
  <view class="result-section" wx:if="{{scheme}}">
    <!-- 主推荐方案 -->
    <view class="scheme-card primary-card">
      <view class="scheme-badge">
        <t-tag theme="primary" size="small">推荐方案</t-tag>
      </view>
      <view class="scheme-name">{{scheme.recommendation}}</view>
      <view class="scheme-notes">{{scheme.notes}}</view>
      
      <!-- 方案参数 -->
      <view class="scheme-params" wx:if="{{scheme.designParams}}">
        <view class="params-title">设计参数参考</view>
        <view class="param-item" wx:for="{{scheme.designParamsList}}" wx:key="name">
          <text class="param-name">{{item.name}}</text>
          <text class="param-value">{{item.value}}</text>
        </view>
      </view>

      <t-button 
        variant="outline" 
        size="small" 
        bind:tap="goSchemeDetail"
        data-scheme="{{scheme.recommendation}}"
      >
        查看详情
      </t-button>
    </view>

    <!-- 备选方案 -->
    <view class="alternatives-section">
      <view class="section-subtitle">备选方案</view>
      <view 
        class="scheme-card alternative-card" 
        wx:for="{{scheme.alternatives}}" 
        wx:key="*this"
        bind:tap="goSchemeDetail"
        data-scheme="{{item}}"
      >
        <view class="scheme-name">{{item}}</view>
        <t-icon name="chevron-right" size="40rpx" color="#999" />
      </view>
    </view>

    <!-- 警告信息 -->
    <view class="warnings-section" wx:if="{{scheme.warnings.length > 0}}">
      <view class="section-subtitle">注意事项</view>
      <view class="warning-item" wx:for="{{scheme.warnings}}" wx:key="*this">
        <t-icon name="info-circle" size="32rpx" color="#ED7B2F" />
        <text class="warning-text">{{item}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="result-actions">
      <t-button variant="outline" block bind:tap="onSave">
        保存到项目
      </t-button>
      <t-button variant="text" block bind:tap="onShare">
        分享方案
      </t-button>
    </view>
  </view>
</view>

<!-- 自定义tabBar -->
<custom-tabbar />
