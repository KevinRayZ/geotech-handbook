<!--pages/knowledge/knowledge.wxml-->
<view class="knowledge-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <t-search
      value="{{searchValue}}"
      placeholder="搜索公式、工法、参数..."
      shape="round"
      bind:change="onSearchInput"
      bind:confirm="onSearchConfirm"
      bind:clear="onSearchClear"
    />
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{isSearching}}">
    <view class="result-header">
      <text>找到 {{searchResults.length}} 条结果</text>
      <text class="clear-btn" bind:tap="onSearchClear">清除</text>
    </view>
    
    <view class="result-list" wx:if="{{searchResults.length > 0}}">
      <view 
        class="result-item" 
        wx:for="{{searchResults}}" 
        wx:key="id"
        data-item="{{item}}"
        bind:tap="onResultTap"
      >
        <view class="result-type" style="background: {{item.categoryColor}}20; color: {{item.categoryColor}}">
          {{item.type === 'formula' ? '公式' : item.type === 'method' ? '工法' : '参数'}}
        </view>
        <view class="result-name">{{item.name}}</view>
        <view class="result-formula" wx:if="{{item.formula}}">{{item.formula}}</view>
        <view class="result-desc">{{item.description}}</view>
        <view class="result-category">{{item.categoryName}}</view>
      </view>
    </view>
    
    <view class="empty-result" wx:else>
      <t-icon name="search" size="48px" color="#ccc"/>
      <text>未找到相关内容</text>
    </view>
  </view>

  <!-- 正常浏览模式 -->
  <view class="browse-mode" wx:if="{{!isSearching}}">
    <!-- 分类选择 -->
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view 
          class="category-item {{currentCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          data-id="{{item.id}}"
          bind:tap="onCategoryChange"
          style="{{currentCategory === item.id ? 'background:' + item.color + '; color: #fff' : ''}}"
        >
          <t-icon name="{{item.icon}}" size="20px"/>
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- Tab切换 -->
    <t-tabs value="{{currentTab}}" bind:change="onTabChange" t-class="content-tabs">
      <t-tab-panel wx:for="{{tabs}}" wx:key="value" value="{{item.value}}" label="{{item.label}} ({{item.value === 'formulas' ? formulas.length : item.value === 'methods' ? methods.length : parameters.length}})" />
    </t-tabs>

    <!-- 公式列表 -->
    <view class="content-list" wx:if="{{currentTab === 'formulas'}}">
      <view class="empty-tip" wx:if="{{formulas.length === 0}}">
        <text>暂无公式数据</text>
      </view>
      <view 
        class="formula-card" 
        wx:for="{{formulas}}" 
        wx:key="id"
        data-item="{{item}}"
        bind:tap="onFormulaTap"
      >
        <view class="card-header">
          <view class="card-title">{{item.name}}</view>
          <view class="card-tag" wx:if="{{item.category}}">{{item.category}}</view>
        </view>
        <view class="card-formula">{{item.formula}}</view>
        <view class="card-desc">{{item.description}}</view>
        <view class="card-tags" wx:if="{{item.tags}}">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
    </view>

    <!-- 工法列表 -->
    <view class="content-list" wx:if="{{currentTab === 'methods'}}">
      <view class="empty-tip" wx:if="{{methods.length === 0}}">
        <text>暂无工法数据</text>
      </view>
      <view 
        class="method-card" 
        wx:for="{{methods}}" 
        wx:key="id"
        data-item="{{item}}"
        bind:tap="onMethodTap"
      >
        <view class="card-header">
          <view class="card-title">{{item.name}}</view>
        </view>
        <view class="card-desc">{{item.description}}</view>
        <view class="card-applicable" wx:if="{{item.applicable}}">
          <text class="label">适用条件：</text>
          <text>{{item.applicable}}</text>
        </view>
      </view>
    </view>

    <!-- 参数列表 -->
    <view class="content-list" wx:if="{{currentTab === 'parameters'}}">
      <view class="empty-tip" wx:if="{{parameters.length === 0}}">
        <text>暂无参数数据</text>
      </view>
      <view 
        class="param-card" 
        wx:for="{{parameters}}" 
        wx:key="name"
        data-item="{{item}}"
        bind:tap="onParamTap"
      >
        <view class="param-header">
          <view class="param-symbol">{{item.symbol}}</view>
          <view class="param-name">{{item.name}}</view>
        </view>
        <view class="param-unit">单位: {{item.unit}}</view>
        <view class="param-desc">{{item.description}}</view>
      </view>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-bar" wx:if="{{stats && !isSearching}}">
    <text>共 {{stats.formulas}} 条公式 | {{stats.methods}} 种工法 | {{stats.parameters}} 个参数</text>
  </view>
</view>
