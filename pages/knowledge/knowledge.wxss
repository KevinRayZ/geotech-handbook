/* pages/knowledge/knowledge.wxss */
.knowledge-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background: #fff;
}

/* 搜索结果 */
.search-results {
  padding: 20rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}

.clear-btn {
  color: #0052d9;
  font-size: 28rpx;
}

.result-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.result-type {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.result-formula {
  font-family: 'Courier New', monospace;
  font-size: 28rpx;
  color: #0052d9;
  background: #f0f7ff;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.result-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.result-category {
  font-size: 24rpx;
  color: #999;
}

.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-result text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

/* 分类选择 */
.category-scroll {
  background: #fff;
  white-space: nowrap;
  padding: 20rpx 0;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  background: #f5f5f5;
  color: #666;
  transition: all 0.3s;
}

.category-item.active {
  color: #fff;
}

/* Tab */
.content-tabs {
  background: #fff;
  margin-bottom: 20rpx;
}

/* 内容列表 */
.content-list {
  padding: 0 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 公式卡片 */
.formula-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.card-tag {
  font-size: 22rpx;
  color: #0052d9;
  background: #f0f7ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.card-formula {
  font-family: 'Courier New', monospace;
  font-size: 28rpx;
  color: #0052d9;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  word-break: break-all;
  line-height: 1.5;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 工法卡片 */
.method-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.card-applicable {
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.card-applicable .label {
  color: #999;
}

/* 参数卡片 */
.param-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.param-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.param-symbol {
  font-size: 36rpx;
  font-weight: 700;
  color: #0052d9;
  font-family: 'Courier New', monospace;
}

.param-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.param-unit {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.param-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 统计栏 */
.stats-bar {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: #999;
}
