/* pages/expert-chat/expert-chat.wxss */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 专家头部 */
.expert-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  color: #fff;
}

.expert-avatar {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-right: 20rpx;
}

.expert-info {
  flex: 1;
}

.expert-name {
  font-size: 32rpx;
  font-weight: bold;
}

.expert-title {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.expert-badge {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.2);
}

.badge-international {
  background: rgba(255,255,255,0.3);
}

.badge-domestic {
  background: rgba(255,200,0,0.3);
}

/* 免责声明 */
.disclaimer {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #fff3e0;
  border-bottom: 1rpx solid #ffe0b2;
}

.disclaimer-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #e65100;
  flex: 1;
}

/* 快捷问题 */
.quick-questions {
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.question-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.question-item {
  font-size: 24rpx;
  color: #1a73e8;
  background: #e3f2fd;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid #90caf9;
}

.question-item:active {
  background: #bbdefb;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 30rpx;
  padding-bottom: 160rpx;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.user-message {
  justify-content: flex-end;
}

.assistant-message {
  justify-content: flex-start;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  background: #e3f2fd;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-avatar {
  background: #1a73e8;
  color: #fff;
  margin-left: 16rpx;
}

.message-content {
  max-width: 70%;
  margin: 0 16rpx;
}

.user-message .message-content {
  background: #1a73e8;
  color: #fff;
  border-radius: 24rpx 24rpx 4rpx 24rpx;
  padding: 20rpx 24rpx;
}

.assistant-message .message-content {
  background: #fff;
  color: #333;
  border-radius: 24rpx 24rpx 24rpx 4rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

.message-time {
  font-size: 20rpx;
  opacity: 0.6;
  margin-top: 8rpx;
  text-align: right;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 16rpx;
}

.action-btn:active {
  color: #1a73e8;
}

/* 加载状态 */
.loading-text {
  display: flex;
  align-items: center;
}

.loading-dots {
  display: flex;
  margin-right: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #1a73e8;
  border-radius: 50%;
  margin: 0 4rpx;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 12rpx 16rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.5;
  max-height: 200rpx;
  padding: 8rpx 16rpx;
  background: transparent;
}

.send-btn {
  font-size: 28rpx;
  color: #ccc;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #e0e0e0;
  margin-left: 12rpx;
}

.send-btn.active {
  color: #fff;
  background: #1a73e8;
}

.send-btn:active {
  opacity: 0.8;
}

.bottom-placeholder {
  height: 20rpx;
}
