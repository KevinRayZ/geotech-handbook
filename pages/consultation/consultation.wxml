<!--pages/consultation/consultation.wxml-->
<view class="consultation-page">
  <!-- 顶部Banner -->
  <view class="banner">
    <view class="banner-bg"></view>
    <view class="banner-content">
      <view class="banner-title">专项方案咨询</view>
      <view class="banner-desc">专业岩土工程团队，为您提供技术支持</view>
    </view>
  </view>

  <!-- 服务介绍 -->
  <view class="section">
    <view class="section-title">我们的服务</view>
    <view class="service-list">
      <view class="service-card" wx:for="{{services}}" wx:key="id">
        <view class="service-icon">
          <t-icon name="{{item.icon}}" size="32px" color="#0052d9"/>
        </view>
        <view class="service-info">
          <view class="service-name">{{item.name}}</view>
          <view class="service-desc">{{item.description}}</view>
          <view class="service-price">{{item.priceRange}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务范围 -->
  <view class="section">
    <view class="section-title">专项方案类型</view>
    <view class="scope-grid">
      <view class="scope-item" wx:for="{{scopeList}}" wx:key="*this">
        <t-icon name="check-circle-filled" size="18px" color="#07a35a"/>
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 服务流程 -->
  <view class="section">
    <view class="section-title">服务流程</view>
    <view class="process-list">
      <view class="process-item" wx:for="{{process}}" wx:key="step">
        <view class="process-step">{{item.step}}</view>
        <view class="process-info">
          <view class="process-title">{{item.title}}</view>
          <view class="process-desc">{{item.description}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="section contact-section">
    <view class="section-title">联系我们</view>
    <view class="contact-list">
      <view class="contact-item" bind:tap="copyWechat">
        <t-icon name="logo-wechat" size="24px" color="#07a35a"/>
        <view class="contact-info">
          <view class="contact-label">微信号</view>
          <view class="contact-value">{{contact.wechat}}</view>
        </view>
        <t-icon name="copy" size="18px" color="#999"/>
      </view>
      <view class="contact-item" bind:tap="callPhone">
        <t-icon name="call" size="24px" color="#0052d9"/>
        <view class="contact-info">
          <view class="contact-label">咨询电话</view>
          <view class="contact-value">{{contact.phone}}</view>
        </view>
        <t-icon name="call" size="18px" color="#999"/>
      </view>
      <view class="contact-item">
        <t-icon name="time" size="24px" color="#e37318"/>
        <view class="contact-info">
          <view class="contact-label">工作时间</view>
          <view class="contact-value">{{contact.workHours}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <t-button theme="primary" size="large" block bind:tap="submitConsultation">
      立即咨询
    </t-button>
  </view>
</view>
