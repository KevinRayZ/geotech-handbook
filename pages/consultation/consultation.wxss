/* pages/consultation/consultation.wxss */
.consultation-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* Banner */
.banner {
  position: relative;
  height: 300rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #0052d9, #0084ff);
}

.banner-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 40rpx;
  color: #fff;
}

.banner-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 分区 */
.section {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 服务列表 */
.service-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.service-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.service-icon {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
}

.service-info {
  flex: 1;
}

.service-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.service-price {
  font-size: 24rpx;
  color: #e37318;
  font-weight: 500;
}

/* 服务范围 */
.scope-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.scope-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #333;
}

/* 服务流程 */
.process-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.process-item {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.process-step {
  width: 56rpx;
  height: 56rpx;
  background: #0052d9;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.process-info {
  flex: 1;
  padding-top: 4rpx;
}

.process-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.process-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 专家卡片 */
.expert-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.expert-avatar {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f0fe;
  border-radius: 50%;
  flex-shrink: 0;
}

.expert-info {
  flex: 1;
}

.expert-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.expert-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.expert-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.expert-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.expert-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* 联系方式 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
