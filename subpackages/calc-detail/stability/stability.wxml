<!-- subpackages/calc-detail/stability/stability.wxml -->
<view class="calc-page">
  <!-- 验算类型选择 -->
  <view class="type-section card">
    <view class="section-title">验算类型</view>
    <view class="check-types">
      <view 
        class="check-type-item {{checkType === item.value ? 'active' : ''}}"
        wx:for="{{checkTypes}}" 
        wx:key="value"
        bind:tap="onCheckTypeChange"
        data-value="{{item.value}}"
      >
        <t-icon name="{{item.icon}}" size="40rpx" />
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 参数输入表单 -->
  <view class="input-section card">
    <view class="section-title">参数输入</view>
    
    <!-- 基坑安全等级 -->
    <view class="form-item">
      <view class="form-label">基坑安全等级 *</view>
      <t-radio-group value="{{params.pitLevel}}" bind:change="onPitLevelChange" t-class="radio-group">
        <t-radio value="一级" label="一级" t-class="radio-item" />
        <t-radio value="二级" label="二级" t-class="radio-item" />
        <t-radio value="三级" label="三级" t-class="radio-item" />
      </t-radio-group>
    </view>

    <!-- 开挖深度 -->
    <view class="form-item">
      <view class="form-label">开挖深度h (m) *</view>
      <t-input 
        type="digit" 
        value="{{params.excavationDepth}}" 
        placeholder="8.0"
        suffix="m"
        bind:change="onInputChange"
        data-key="excavationDepth"
      />
    </view>

    <!-- 入土深度 -->
    <view class="form-item" wx:if="{{checkType !== 'antiPiping' && checkType !== 'antiBurst'}}">
      <view class="form-label">入土深度t (m) *</view>
      <t-input 
        type="digit" 
        value="{{params.embedDepth}}" 
        placeholder="5.0"
        suffix="m"
        bind:change="onInputChange"
        data-key="embedDepth"
      />
    </view>

    <!-- 土体重度 -->
    <view class="form-item">
      <view class="form-label">土体重度γ (kN/m³) *</view>
      <t-input 
        type="digit" 
        value="{{params.gamma}}" 
        placeholder="18.5"
        suffix="kN/m³"
        bind:change="onInputChange"
        data-key="gamma"
      />
    </view>

    <!-- 粘聚力 -->
    <view class="form-item" wx:if="{{checkType !== 'antiPiping' && checkType !== 'antiBurst'}}">
      <view class="form-label">粘聚力c (kPa) *</view>
      <t-input 
        type="digit" 
        value="{{params.c}}" 
        placeholder="15"
        suffix="kPa"
        bind:change="onInputChange"
        data-key="c"
      />
    </view>

    <!-- 内摩擦角 -->
    <view class="form-item" wx:if="{{checkType !== 'antiPiping' && checkType !== 'antiBurst'}}">
      <view class="form-label">内摩擦角φ (°) *</view>
      <t-input 
        type="digit" 
        value="{{params.phi}}" 
        placeholder="20"
        suffix="°"
        bind:change="onInputChange"
        data-key="phi"
      />
    </view>

    <!-- 地面超载 -->
    <view class="form-item" wx:if="{{checkType !== 'antiPiping' && checkType !== 'antiBurst'}}">
      <view class="form-label">地面超载q (kPa)</view>
      <t-input 
        type="digit" 
        value="{{params.surcharge}}" 
        placeholder="10"
        suffix="kPa"
        bind:change="onInputChange"
        data-key="surcharge"
      />
    </view>

    <!-- 抗流土特有参数 -->
    <block wx:if="{{checkType === 'antiPiping'}}">
      <t-divider />
      <view class="section-subtitle">抗流土参数</view>
      
      <view class="form-item">
        <view class="form-label">地下水位深度 (m)</view>
        <t-input 
          type="digit" 
          value="{{params.waterLevel}}" 
          placeholder="2.0"
          suffix="m"
          bind:change="onInputChange"
          data-key="waterLevel"
        />
      </view>
    </block>

    <!-- 抗突涌特有参数 -->
    <block wx:if="{{checkType === 'antiBurst'}}">
      <t-divider />
      <view class="section-subtitle">抗突涌参数</view>
      
      <view class="form-item">
        <view class="form-label">承压水头高度 (m)</view>
        <t-input 
          type="digit" 
          value="{{params.confinedWaterHead}}" 
          placeholder="10"
          suffix="m"
          bind:change="onInputChange"
          data-key="confinedWaterHead"
        />
      </view>

      <view class="form-item">
        <view class="form-label">承压层顶板厚度 (m)</view>
        <t-input 
          type="digit" 
          value="{{params.confinedTopThickness}}" 
          placeholder="3"
          suffix="m"
          bind:change="onInputChange"
          data-key="confinedTopThickness"
        />
      </view>
    </block>
  </view>

  <!-- 计算按钮 -->
  <view class="action-section">
    <t-button 
      theme="primary" 
      size="large" 
      block 
      bind:tap="onCalculate"
      loading="{{loading}}"
    >
      开始验算
    </t-button>
  </view>

  <!-- 计算结果 -->
  <view class="result-section" wx:if="{{result}}">
    <view class="result-header">
      <t-icon 
        name="{{result.passed ? 'check-circle-filled' : 'close-circle-filled'}}" 
        color="{{result.passed ? '#00A870' : '#E34D59'}}" 
        size="48rpx" 
      />
      <text class="result-title">{{result.passed ? '验算通过' : '验算不通过'}}</text>
    </view>

    <!-- 安全系数 -->
    <view class="fs-card {{result.passed ? 'passed' : 'failed'}}">
      <view class="fs-label">安全系数 Fs</view>
      <view class="fs-value">{{result.Fs}}</view>
      <view class="fs-required">要求 ≥ {{result.requiredFs}}</view>
    </view>

    <!-- 详细结果 -->
    <view class="detail-cards">
      <view class="detail-card" wx:for="{{result.details}}" wx:key="name">
        <view class="detail-name">{{item.name}}</view>
        <view class="detail-value">{{item.value}}</view>
      </view>
    </view>

    <!-- 计算摘要 -->
    <view class="result-summary {{result.passed ? 'summary-pass' : 'summary-fail'}}">
      <t-icon name="info-circle" size="32rpx" />
      <text>{{result.summary}}</text>
    </view>

    <!-- 计算公式 -->
    <view class="result-formula" wx:if="{{result.formula}}">
      <view class="ref-title">计算公式</view>
      <view class="formula-display">{{result.formula}}</view>
    </view>

    <!-- 参考规范 -->
    <view class="result-references">
      <view class="ref-title">参考规范</view>
      <t-cell 
        wx:for="{{result.references}}" 
        wx:key="code" 
        title="{{item.code}}" 
        note="{{item.description}}"
      />
    </view>

    <!-- 操作按钮 -->
    <view class="result-actions">
      <t-button variant="outline" bind:tap="onSave">保存结果</t-button>
      <t-button variant="text" bind:tap="onReset">重新计算</t-button>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
