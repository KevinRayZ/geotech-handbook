/* subpackages/calc-detail/stability/stability.wxss */

.calc-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 验算类型选择 */
.type-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 16rpx;
}

.check-types {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.check-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  min-width: 140rpx;
  transition: all 0.3s;
}

.check-type-item.active {
  background-color: #E8F0FE;
  border: 2rpx solid #0052D9;
}

.check-type-item text {
  font-size: 24rpx;
  color: #666;
}

.check-type-item.active text {
  color: #0052D9;
  font-weight: 500;
}

/* 参数输入 */
.input-section {
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  min-width: 160rpx;
}

/* 计算按钮 */
.action-section {
  margin-bottom: 32rpx;
}

/* 计算结果 */
.result-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* 安全系数卡片 */
.fs-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.fs-card.passed {
  background-color: #E8F5E9;
  border: 2rpx solid #00A870;
}

.fs-card.failed {
  background-color: #FFEBEE;
  border: 2rpx solid #E34D59;
}

.fs-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.fs-value {
  font-size: 72rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.fs-card.passed .fs-value {
  color: #00A870;
}

.fs-card.failed .fs-value {
  color: #E34D59;
}

.fs-required {
  font-size: 26rpx;
  color: #666;
}

/* 详细结果 */
.detail-cards {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.detail-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
}

.detail-name {
  font-size: 26rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

/* 计算摘要 */
.result-summary {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.result-summary.summary-pass {
  background-color: #E8F5E9;
}

.result-summary.summary-fail {
  background-color: #FFEBEE;
}

.result-summary text {
  font-size: 28rpx;
  line-height: 1.6;
}

/* 计算公式 */
.result-formula {
  margin-bottom: 24rpx;
}

.ref-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.formula-display {
  font-family: 'Times New Roman', serif;
  font-size: 28rpx;
  font-style: italic;
  color: #0052D9;
  background-color: #f8f9fa;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

/* 参考规范 */
.result-references {
  margin-bottom: 32rpx;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
