/* subpackages/calc-detail/earth-pressure/earth-pressure.wxss */

.calc-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 类型选择 */
.type-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 16rpx;
}

/* 参数输入 */
.input-section {
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  min-width: 200rpx;
}

/* 计算按钮 */
.action-section {
  margin-bottom: 32rpx;
}

/* 计算结果 */
.result-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* 结果卡片 */
.result-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.result-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.result-label {
  font-size: 28rpx;
  color: #666;
}

.result-value {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.value-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #0052D9;
}

.value-unit {
  font-size: 24rpx;
  color: #666;
}

/* 计算摘要 */
.result-summary {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 24rpx;
  background-color: #E8F0FE;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.result-summary text {
  font-size: 28rpx;
  color: #0052D9;
  line-height: 1.6;
}

/* 警告信息 */
.result-warnings {
  margin-bottom: 24rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background-color: #FFF8E1;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.warning-item text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 参考规范 */
.result-references {
  margin-bottom: 24rpx;
}

.ref-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

/* 公式展示 */
.result-formula {
  margin-bottom: 32rpx;
}

.formula-display {
  font-family: 'Times New Roman', serif;
  font-size: 32rpx;
  font-style: italic;
  color: #0052D9;
  background-color: #f8f9fa;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
