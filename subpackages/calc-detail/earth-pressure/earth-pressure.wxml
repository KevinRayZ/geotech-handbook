<!-- subpackages/calc-detail/earth-pressure/earth-pressure.wxml -->
<view class="calc-page">
  <!-- 计算类型选择 -->
  <view class="type-section card">
    <view class="section-title">计算理论</view>
    <t-tabs value="{{calcType}}" bind:change="onTypeChange">
      <t-tab-panel value="rankine" label="朗肯理论" />
      <t-tab-panel value="coulomb" label="库仑理论" />
    </t-tabs>
  </view>

  <!-- 参数输入表单 -->
  <view class="input-section card">
    <view class="section-title">参数输入</view>
    
    <!-- 土压力类型 -->
    <view class="form-item">
      <view class="form-label">土压力类型 *</view>
      <t-radio-group value="{{params.pressureType}}" bind:change="onPressureTypeChange" t-class="radio-group">
        <t-radio value="主动" label="主动土压力" t-class="radio-item" />
        <t-radio value="被动" label="被动土压力" t-class="radio-item" />
        <t-radio value="静止" label="静止土压力" t-class="radio-item" />
      </t-radio-group>
    </view>

    <!-- 土体重度 -->
    <view class="form-item">
      <view class="form-label">土体重度γ (kN/m³) *</view>
      <t-input 
        type="digit" 
        value="{{params.gamma}}" 
        placeholder="18.5"
        suffix="kN/m³"
        bind:change="onInputChange"
        data-key="gamma"
      />
      <view class="form-hint">常见值：黏性土18~20，砂土18~20，软土15~18</view>
    </view>

    <!-- 内摩擦角 -->
    <view class="form-item">
      <view class="form-label">内摩擦角φ (°) *</view>
      <t-input 
        type="digit" 
        value="{{params.phi}}" 
        placeholder="25"
        suffix="°"
        bind:change="onInputChange"
        data-key="phi"
      />
      <view class="form-hint">常见值：黏性土8~25，砂土25~40</view>
    </view>

    <!-- 粘聚力 -->
    <view class="form-item">
      <view class="form-label">粘聚力c (kPa)</view>
      <t-input 
        type="digit" 
        value="{{params.c}}" 
        placeholder="0"
        suffix="kPa"
        bind:change="onInputChange"
        data-key="c"
      />
      <view class="form-hint">无粘性土填0，黏性土一般10~60kPa</view>
    </view>

    <!-- 计算深度 -->
    <view class="form-item">
      <view class="form-label">计算深度z (m) *</view>
      <t-input 
        type="digit" 
        value="{{params.depth}}" 
        placeholder="5.0"
        suffix="m"
        bind:change="onInputChange"
        data-key="depth"
      />
    </view>

    <!-- 地面超载 -->
    <view class="form-item">
      <view class="form-label">地面超载q (kPa)</view>
      <t-input 
        type="digit" 
        value="{{params.surcharge}}" 
        placeholder="0"
        suffix="kPa"
        bind:change="onInputChange"
        data-key="surcharge"
      />
      <view class="form-hint">一般取10~20kPa</view>
    </view>

    <!-- 库仑理论特有参数 -->
    <block wx:if="{{calcType === 'coulomb'}}">
      <t-divider />
      <view class="section-subtitle">库仑理论参数</view>
      
      <view class="form-item">
        <view class="form-label">墙背倾角α (°)</view>
        <t-input 
          type="digit" 
          value="{{params.alpha}}" 
          placeholder="0"
          suffix="°"
          bind:change="onInputChange"
          data-key="alpha"
        />
        <view class="form-hint">俯斜为正，仰斜为负</view>
      </view>

      <view class="form-item">
        <view class="form-label">墙土摩擦角δ (°)</view>
        <t-input 
          type="digit" 
          value="{{params.delta}}" 
          placeholder="0"
          suffix="°"
          bind:change="onInputChange"
          data-key="delta"
        />
        <view class="form-hint">一般取φ/3~φ/2</view>
      </view>

      <view class="form-item">
        <view class="form-label">填土坡角β (°)</view>
        <t-input 
          type="digit" 
          value="{{params.beta}}" 
          placeholder="0"
          suffix="°"
          bind:change="onInputChange"
          data-key="beta"
        />
      </view>
    </block>
  </view>

  <!-- 计算按钮 -->
  <view class="action-section">
    <t-button 
      theme="primary" 
      size="large" 
      block 
      bind:tap="onCalculate"
      loading="{{loading}}"
    >
      开始计算
    </t-button>
  </view>

  <!-- 计算结果 -->
  <view class="result-section" wx:if="{{result}}">
    <view class="result-header">
      <t-icon name="check-circle-filled" color="#00A870" size="48rpx" />
      <text class="result-title">计算完成</text>
    </view>

    <!-- 结果卡片 -->
    <view class="result-cards">
      <view class="result-card" wx:for="{{result.items}}" wx:key="key">
        <view class="result-label">{{item.label}}</view>
        <view class="result-value">
          <text class="value-number">{{item.value}}</text>
          <text class="value-unit" wx:if="{{item.unit}}">{{item.unit}}</text>
        </view>
      </view>
    </view>

    <!-- 计算摘要 -->
    <view class="result-summary">
      <t-icon name="info-circle" size="32rpx" color="#0052D9" />
      <text>{{result.summary}}</text>
    </view>

    <!-- 警告信息 -->
    <view class="result-warnings" wx:if="{{result.warnings.length > 0}}">
      <view class="warning-item" wx:for="{{result.warnings}}" wx:key="*this">
        <t-icon name="warning" size="32rpx" color="#ED7B2F" />
        <text>{{item}}</text>
      </view>
    </view>

    <!-- 参考规范 -->
    <view class="result-references">
      <view class="ref-title">参考规范</view>
      <t-cell 
        wx:for="{{result.references}}" 
        wx:key="code" 
        title="{{item.code}}" 
        note="{{item.description}}"
      />
    </view>

    <!-- 公式展示 -->
    <view class="result-formula">
      <view class="ref-title">计算公式</view>
      <view class="formula-display">{{result.formula}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="result-actions">
      <t-button variant="outline" bind:tap="onSave">保存到项目</t-button>
      <t-button variant="outline" bind:tap="onShare">分享结果</t-button>
      <t-button variant="text" bind:tap="onReset">重新计算</t-button>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
