.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.formula-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #eee;
}

.formula-box {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #0052D9;
  margin-bottom: 16rpx;
}

.formula-text {
  font-size: 28rpx;
  color: #333;
  font-family: monospace;
  line-height: 1.6;
}

.formula-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.params-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.param-input {
  margin-bottom: 24rpx;
}

.param-input:last-child {
  margin-bottom: 0;
}

.param-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.param-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.param-unit {
  font-size: 24rpx;
  color: #999;
}

.param-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.actions t-button {
  flex: 1;
}

.result-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.result-box {
  background-color: #f0f9ff;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 2rpx solid #bae6fd;
}

.result-item {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-label {
  font-size: 28rpx;
  color: #666;
}

.result-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #0052D9;
}

.result-unit {
  font-size: 24rpx;
  color: #999;
}

.result-message {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
