.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.source {
  font-size: 24rpx;
  color: #999;
}

.content {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #eee;
}

.formula-section {
  margin-bottom: 32rpx;
}

.formula-box {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #0052D9;
}

.formula-text {
  font-size: 28rpx;
  color: #333;
  font-family: monospace;
  line-height: 1.6;
}

.desc-section {
  margin-bottom: 32rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.params-section {
  margin-bottom: 32rpx;
}

.param-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.param-item:last-child {
  border-bottom: none;
}

.param-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.param-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.condition-section {
  margin-bottom: 32rpx;
}

.condition-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.condition-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.reference-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #eee;
}

.reference-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
