.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 180rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #eee;
}

/* 项目信息 */
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 方案卡片 */
.scheme-card {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.scheme-card:last-child {
  margin-bottom: 0;
}

.primary-scheme {
  border-left: 6rpx solid #00A870;
}

.alternative-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-left: 6rpx solid #0052D9;
}

.scheme-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.scheme-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.scheme-reason {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.scheme-brief {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

/* 方案详情 */
.scheme-advantages,
.design-params,
.scheme-conditions {
  margin-bottom: 24rpx;
}

.advantages-title,
.params-title,
.conditions-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.advantage-item,
.condition-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.param-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.param-item:last-child {
  border-bottom: none;
}

.param-name {
  font-size: 24rpx;
  color: #666;
}

.param-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 注意事项 */
.warning-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.warning-item:last-child {
  margin-bottom: 0;
}

.warning-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 计算工具 */
.calculator-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.calculator-item:last-child {
  border-bottom: none;
}

.calculator-info {
  flex: 1;
}

.calculator-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.calculator-desc {
  font-size: 22rpx;
  color: #999;
}

/* 操作按钮 */
.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.actions t-button {
  flex: 1;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
  padding: 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
