[
  {
    "id": "formula-slope-stability",
    "name": "边坡稳定性安全系数",
    "formula": "Fs = Σ(抗滑力) / Σ(下滑力)",
    "description": "边坡稳定性分析的基本公式，用于评估边坡的安全状态",
    "params": [
      {
        "name": "抗滑力",
        "description": "抵抗滑动的力"
      },
      {
        "name": "下滑力",
        "description": "促使滑动的力"
      }
    ],
    "category": "稳定性",
