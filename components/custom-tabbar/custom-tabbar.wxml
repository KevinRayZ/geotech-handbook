<view class="tabbar">
  <view 
    class="tabbar-item {{selected === index ? 'active' : ''}}" 
    wx:for="{{list}}" 
    wx:key="index"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <t-icon 
      name="{{selected === index ? item.selectedIconPath : item.iconPath}}" 
      size="48rpx" 
      color="{{selected === index ? selectedColor : color}}"
    />
    <view class="tabbar-text" style="color: {{selected === index ? selectedColor : color}}">
      {{item.text}}
    </view>
  </view>
</view>
